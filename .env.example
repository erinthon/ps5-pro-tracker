# Banco de dados MySQL
DATABASE_URL=mysql://usuario:senha@localhost:3306/ps5-pro-tracker

# Chave secreta para assinar JWT de sessão (mínimo 32 caracteres aleatórios)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-min-32-chars

# ID da aplicação (pode ser qualquer string identificadora)
VITE_APP_ID=ps5-pro-tracker

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URIs: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth externo (opcional, não necessário para login com Google)
# OAUTH_SERVER_URL=
# OWNER_OPEN_ID=
